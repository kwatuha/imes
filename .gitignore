# Environment files
# Root .env: secrets for docker-compose.prod.yml (DB passwords, etc.) — never commit
.env
# IMPORTANT: .env.development and .env.production are committed (non-secret config)
# Only .env.local files (with secrets/local overrides) are ignored
.env.local
.env*.local
*.env.local
# Do NOT ignore .env.development or .env.production - they're part of the config!

# Dependencies
node_modules/
*/node_modules/

# Build outputs
dist/
build/
*/dist/
*/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# OS files
.DS_Store
Thumbs.db

# IDE files
.vscode/
.idea/
*.swp
*.swo
*.sql
*.md
*~
api/uploads/
api/migrations/

# DB dumps (scripts/sync-kemri-projects-to-remote.sh)
kemri_projects_dump.sql.gz
kemri_projects_dump.sql
feedback_pull_from_remote.sql.gz

# Shell / editor noise (never commit)
last_history.txt
.~lock.*#
**/.~lock.*#

# Temporary files
tmp/
temp/
*.tmp

# Database
*.sql.backup
*.sql.bak

# Uploads (comment out if you want to track uploads)
# uploads/

# Docker volumes data
db_data/

# Coverage
coverage/
.nyc_output/
scripts/

