# Production secrets for docker-compose.prod.yml
# Copy to .env in this directory (same folder as docker-compose.prod.yml):
#   cp .env.example .env
# Edit .env — never commit .env (see .gitignore).
#
# Docker Compose loads .env automatically for ${VAR} substitution.
# If .env is missing, compose uses the defaults baked into docker-compose.prod.yml (:-...).

# MySQL (must match between mysql_db and api)
MYSQL_ROOT_PASSWORD=root_password
MYSQL_DATABASE=imbesdb
MYSQL_USER=impesUser
MYSQL_PASSWORD=Admin2010impes
MYSQL_PORT=3307

# Published host ports (optional; defaults match previous compose)
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443
API_PORT=3000
PUBLIC_DASHBOARD_PORT=5174
